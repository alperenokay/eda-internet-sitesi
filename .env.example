# PostgreSQL (Render'da otomatik gelir)
DATABASE_URL=postgresql://postgres:pass@localhost:5432/mepackage
# Yerel Postgres için false; Render için true veya boş bırak
DATABASE_SSL=false

# Oturum (admin panel, imzalı cookie)
SESSION_SECRET=dev-secret-degistir

# İlk admin kullanıcı (scripts/admin-create.mjs)
# ADMIN_EMAIL=alperen@example.com
# ADMIN_PASSWORD=guclu-parola

# SMTP (Spacemail, opsiyonel; yoksa yalnızca DB kaydı)
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_USER=info@me-package.com
SMTP_PASS=
NOTIFY_TO=lab@me-package.com

# KVKK (aydınlatma metni iletişim, varsayılan info@me-package.com)
KVKK_CONTACT_EMAIL=
# Başvuru saklama süresi (ay), varsayılan 24
DATA_RETENTION_MONTHS=24

# Google Search Console doğrulama (meta tag içeriği, boş bırakılabilir)
GSC_VERIFICATION=

# Node / Render (genelde platform set eder)
# PORT=4321
# NODE_ENV=production
