# PostgreSQL (Render'da otomatik gelir)
DATABASE_URL=postgresql://postgres:pass@localhost:5432/sagirhukuk
# Yerel Postgres için false; Render için true veya boş bırak
DATABASE_SSL=false

# Oturum (admin panel, imzalı cookie)
SESSION_SECRET=dev-secret-degistir

# İlk admin kullanıcı (npm run admin:create)
# ADMIN_EMAIL=av.edasagir@sagirhukuk.net
# ADMIN_PASSWORD=guclu-parola

# SMTP (opsiyonel; yoksa yalnızca DB kaydı)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=av.edasagir@sagirhukuk.net
SMTP_PASS=
NOTIFY_TO=av.edasagir@sagirhukuk.net

# KVKK (aydınlatma metni iletişim, varsayılan av.edasagir@sagirhukuk.net)
KVKK_CONTACT_EMAIL=
# İletişim saklama süresi (ay), varsayılan 24
DATA_RETENTION_MONTHS=24

# Google Search Console doğrulama (meta tag içeriği, boş bırakılabilir)
GSC_VERIFICATION=

# Node / Render (genelde platform set eder)
# PORT=4321
# NODE_ENV=production
