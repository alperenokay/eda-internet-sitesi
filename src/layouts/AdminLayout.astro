---
import "@/styles/global.css";
import { BRAND_SHORT } from "@/lib/site";

export interface Props {
  title?: string;
}

const { title = "Yönetim paneli" } = Astro.props;
const current = Astro.url.pathname;
const nav = [
  { href: "/admin", label: "Özet", match: (p: string) => p === "/admin" },
  { href: "/admin/icerik", label: "İçerik", match: (p: string) => p.startsWith("/admin/icerik") },
  { href: "/admin/blog", label: "Blog", match: (p: string) => p.startsWith("/admin/blog") },
  { href: "/admin/basvurular", label: "Mesajlar", match: (p: string) => p === "/admin/basvurular" },
];
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} · {BRAND_SHORT}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
    />
  </head>
  <body class="min-h-screen bg-surface text-ink">
    <header class="border-b border-line bg-paper">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-4">
        <div>
          <p class="font-display text-lg font-semibold">Yönetim paneli</p>
          <p class="text-xs text-muted">{BRAND_SHORT}</p>
        </div>
        <nav aria-label="Admin menü">
          <ul class="flex flex-wrap items-center gap-4 text-sm">
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "no-underline",
                    item.match(current) ? "font-semibold text-green-deep" : "text-muted hover:text-heading",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
            <li>
              <button
                type="button"
                id="admin-logout"
                class="cursor-pointer border-none bg-transparent p-0 text-sm text-muted hover:text-ink"
              >
                Çıkış
              </button>
            </li>
          </ul>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
    <script>
      document.getElementById("admin-logout")?.addEventListener("click", async () => {
        await fetch("/api/admin/logout", { method: "POST" });
        window.location.href = "/admin/login";
      });
    </script>
  </body>
</html>
