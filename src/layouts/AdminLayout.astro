---
import "@/styles/global.css";
import { BRAND_SHORT } from "@/lib/site";

export interface Props {
  title?: string;
}

const { title = "Yönetim paneli" } = Astro.props;
const current = Astro.url.pathname;
const nav = [
  { href: "/admin", label: "Özet", hint: "Sayılar ve kısayollar", match: (p: string) => p === "/admin" },
  {
    href: "/admin/icerik",
    label: "Sayfa metinleri",
    hint: "Menü, ana sayfa, iletişim",
    match: (p: string) => p.startsWith("/admin/icerik"),
  },
  {
    href: "/admin/blog",
    label: "Yayınlar",
    hint: "Blog yazıları",
    match: (p: string) => p.startsWith("/admin/blog"),
  },
  {
    href: "/admin/basvurular",
    label: "Mesajlar",
    hint: "İletişim formu",
    match: (p: string) => p === "/admin/basvurular",
  },
];
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} · {BRAND_SHORT}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
    />
  </head>
  <body class="min-h-screen bg-surface text-ink">
    <header class="border-b border-line bg-paper">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-4">
        <div>
          <p class="font-display text-lg font-semibold">Yönetim paneli</p>
          <p class="text-xs text-muted">{BRAND_SHORT} · Site içeriğini buradan güncellersiniz</p>
        </div>
        <nav aria-label="Admin menü">
          <ul class="flex flex-wrap items-center gap-1 sm:gap-2">
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  title={item.hint}
                  class:list={[
                    "block rounded-[var(--radius-sm)] px-3 py-2 text-sm no-underline",
                    item.match(current)
                      ? "bg-surface font-semibold text-green-deep"
                      : "text-muted hover:bg-surface/70 hover:text-heading",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
            <li>
              <button
                type="button"
                id="admin-logout"
                class="cursor-pointer rounded-[var(--radius-sm)] border-none bg-transparent px-3 py-2 text-sm text-muted hover:bg-surface/70 hover:text-ink"
              >
                Çıkış
              </button>
            </li>
          </ul>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
    <script>
      document.getElementById("admin-logout")?.addEventListener("click", async () => {
        await fetch("/api/admin/logout", { method: "POST" });
        window.location.href = "/admin/login";
      });
    </script>
  </body>
</html>
