---
import Logo from "@/components/ui/Logo.astro";
import ButtonLink from "@/components/ui/ButtonLink.astro";
import FormattedText from "@/components/ui/FormattedText.astro";
import type { GlobalContent } from "@/lib/content-defaults";

export interface Props {
  global: GlobalContent;
}

const { global } = Astro.props;
---

<header class="sticky top-0 z-40 bg-white shadow-[0_1px_0_var(--color-line)]">
  <div class="site-header-bar" aria-hidden="true"></div>
  <div class="mx-auto flex min-h-[78px] max-w-[1360px] items-center gap-4 px-6 py-3 sm:min-h-[84px] sm:px-10">
    <a href="/" class="flex shrink-0 items-center no-underline" aria-label="Ana sayfa, Sağır Hukuk">
      <Logo variant="header" />
    </a>
    <nav aria-label="Ana menü" class="hidden min-w-0 flex-1 justify-center md:flex">
      <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-[0.9rem] font-medium">
        {global.headerNav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-muted no-underline transition-colors hover:text-heading"
            >
              <FormattedText text={item.label} as="span" />
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="ml-auto flex shrink-0 items-center gap-4">
      <nav aria-label="Ana menü" class="md:hidden">
        <ul class="flex items-center gap-x-4 text-[0.88rem] font-medium">
          {global.headerNav.map((item) => (
            <li>
              <a href={item.href} class="text-muted no-underline hover:text-heading">
                <FormattedText text={item.label} as="span" />
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <ButtonLink href={global.headerCtaHref} variant="primary">
        <FormattedText text={global.headerCtaLabel} as="span" />
      </ButtonLink>
    </div>
  </div>
</header>
