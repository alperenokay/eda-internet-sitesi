---
import SingleLeaf from "@/components/ui/botanic/SingleLeaf.astro";
import Logo from "@/components/ui/Logo.astro";

const nav = [
  { href: "/danismanlik", label: "Danışmanlık" },
  { href: "/analizler", label: "Analizler" },
  { href: "/blog", label: "Blog" },
  { href: "/iletisim", label: "İletişim" },
];
---

<footer class="relative overflow-hidden bg-panel text-white/60">
  <SingleLeaf variant="footer" />
  <div class="relative mx-auto max-w-[1360px] px-6 py-12 sm:px-10">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <Logo variant="footer" />
        <p class="mt-3 max-w-md text-sm text-white/60">
          PPWR (EU 2025/40) uyum danışmanlığı ve ambalaj analizleri. Marine Emission alt markası.
        </p>
      </div>
      <nav aria-label="Alt menü">
        <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
          <li><a href="/danismanlik" class="text-white/60 no-underline hover:text-white">Danışmanlık</a></li>
          <li><a href="/analizler" class="text-white/60 no-underline hover:text-white">Analizler</a></li>
          <li><a href="/blog" class="text-white/60 no-underline hover:text-white">Blog</a></li>
          <li><a href="/iletisim" class="text-white/60 no-underline hover:text-white">İletişim</a></li>
          <li><a href="/kvkk" class="text-white/60 no-underline hover:text-white">KVKK</a></li>
        </ul>
      </nav>
    </div>
    <p class="mt-8 border-t border-white/10 pt-6 text-xs text-white/45">
      © {new Date().getFullYear()} Marine Emission. Tüm hakları saklıdır.
    </p>
  </div>
</footer>
