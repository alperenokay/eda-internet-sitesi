---
import AdminRichToolbar from "./AdminRichToolbar.astro";
import AdminSection from "../AdminSection.astro";

export interface Props {
  path: string;
  label: string;
  items: { href: string; label: string }[];
  sectionId?: string;
  location?: string;
  hint?: string;
}

const {
  path,
  label,
  items,
  sectionId,
  location,
  hint = "Her satır bir menü öğesi: soldaki adres, sağdaki görünen metin.",
} = Astro.props;
const inputClass =
  "block w-full rounded-[var(--radius-sm)] border border-line bg-paper px-3 py-2 text-sm font-normal leading-relaxed";
---

<AdminSection id={sectionId} title={label} location={location} hint={hint} listPath={path}>
  <div class="rich-text-field" data-rich-text-root>
    <AdminRichToolbar />
    <p class="text-xs text-muted">Biçimlendirme yalnızca menü metni alanına uygulanır.</p>
    <div class="list-rows space-y-3">
      {items.map((item, i) => (
        <div class="list-row grid gap-2 rounded-[var(--radius-sm)] border border-line/60 bg-surface/50 p-3 sm:grid-cols-[1fr_1fr_auto]">
          <div>
            <label class="mb-1 block text-xs text-muted" for={`${path}-${i}-href`}>Sayfa adresi</label>
            <input
              id={`${path}-${i}-href`}
              type="text"
              data-field={`${path}.${i}.href`}
              value={item.href}
              placeholder="/ornek"
              class={inputClass}
            />
          </div>
          <div>
            <label class="mb-1 block text-xs text-muted" for={`${path}-${i}-label`}>Menüde görünen metin</label>
            <input
              id={`${path}-${i}-label`}
              type="text"
              data-field={`${path}.${i}.label`}
              data-rich-input
              value={item.label}
              placeholder="Menü metni"
              class={inputClass}
            />
          </div>
          <div class="flex items-end">
            <button type="button" class="list-remove text-sm text-red-700">Kaldır</button>
          </div>
        </div>
      ))}
    </div>
    <button type="button" class="list-add mt-3 text-sm font-semibold text-green-deep" data-list-path={path}>
      Menü öğesi ekle
    </button>
  </div>
</AdminSection>
