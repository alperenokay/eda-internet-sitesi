---
import AdminField from "./AdminField.astro";
import AdminSection from "../AdminSection.astro";

export interface Props {
  prefix: string;
  hero: {
    eyebrow: string;
    chip?: string;
    title: string;
    titleHighlight: string;
    lead: string;
    primaryHref: string;
    primaryLabel: string;
    secondaryHref: string;
    secondaryLabel: string;
    showTrustPanel?: boolean;
  };
  showChip?: boolean;
  showTrust?: boolean;
  sectionId?: string;
  location?: string;
}

const {
  prefix,
  hero,
  showChip = false,
  showTrust = false,
  sectionId = "section-hero",
  location = "Sayfanın en üstü, büyük başlık ve butonlar",
} = Astro.props;
---

<AdminSection id={sectionId} title="Sayfa başı (üst bölüm)" location={location}>
  <AdminField
    label="Küçük üst etiket"
    field={`${prefix}.eyebrow`}
    value={hero.eyebrow}
    hint='Başlığın üstündeki ince satır (ör. "Sağır Hukuk & Danışmanlık").'
  />
  {showChip && (
    <AdminField
      label="İsim rozeti"
      field={`${prefix}.chip`}
      value={hero.chip ?? ""}
      hint="Başlık yakınında görünen kısa unvan veya etiket."
    />
  )}
  <AdminField label="Ana başlık" field={`${prefix}.title`} value={hero.title} />
  <AdminField
    label="Vurgulu kelime"
    field={`${prefix}.titleHighlight`}
    value={hero.titleHighlight}
    hint="Başlıkta yeşil/altın renkle vurgulanan kelime."
  />
  <AdminField
    label="Kısa açıklama"
    field={`${prefix}.lead`}
    value={hero.lead}
    rows={3}
    hint="Başlığın altındaki bir veya iki cümlelik tanıtım metni."
  />
  <div class="grid gap-4 sm:grid-cols-2">
    <AdminField label="Birincil buton linki" field={`${prefix}.primaryHref`} value={hero.primaryHref} plain />
    <AdminField label="Birincil buton metni" field={`${prefix}.primaryLabel`} value={hero.primaryLabel} />
    <AdminField label="İkincil buton linki" field={`${prefix}.secondaryHref`} value={hero.secondaryHref} plain />
    <AdminField label="İkincil buton metni" field={`${prefix}.secondaryLabel`} value={hero.secondaryLabel} />
  </div>
  {showTrust && (
    <label class="flex items-center gap-2 text-sm">
      <input type="checkbox" data-field={`${prefix}.showTrustPanel`} checked={hero.showTrustPanel} />
      Sağdaki güven panelini göster (çalışma saatleri ve iletişim özeti)
    </label>
  )}
</AdminSection>
