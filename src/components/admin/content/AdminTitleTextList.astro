---
import AdminRichToolbar from "./AdminRichToolbar.astro";
import AdminSection from "../AdminSection.astro";

export interface Props {
  path: string;
  label: string;
  items: { title: string; text: string }[];
  sectionId?: string;
  location?: string;
  hint?: string;
}

const {
  path,
  label,
  items,
  sectionId,
  location,
  hint = "Her kartın bir başlığı ve kısa açıklaması vardır.",
} = Astro.props;
const inputClass =
  "block w-full rounded-[var(--radius-sm)] border border-line bg-paper px-3 py-2 text-sm font-normal leading-relaxed";
---

<AdminSection id={sectionId} title={label} location={location} hint={hint} listPath={path}>
  <div class="rich-text-field" data-rich-text-root>
    <AdminRichToolbar />
    <div class="list-rows space-y-4">
      {items.map((item, i) => (
        <div class="list-row space-y-2 rounded-[var(--radius-sm)] border border-line/60 bg-surface/50 p-3">
          <label class="block text-xs text-muted" for={`${path}-${i}-title`}>Kart başlığı</label>
          <input
            id={`${path}-${i}-title`}
            type="text"
            data-field={`${path}.${i}.title`}
            data-rich-input
            value={item.title}
            placeholder="Başlık"
            class={inputClass}
          />
          <label class="block text-xs text-muted" for={`${path}-${i}-text`}>Kart metni</label>
          <textarea
            id={`${path}-${i}-text`}
            data-field={`${path}.${i}.text`}
            data-rich-input
            rows={2}
            placeholder="Metin"
            class={inputClass}>{item.text}</textarea>
          <button type="button" class="list-remove text-sm text-red-700">Kartı kaldır</button>
        </div>
      ))}
    </div>
    <button type="button" class="list-add mt-3 text-sm font-semibold text-green-deep" data-list-path={path} data-list-type="titleText">
      Kart ekle
    </button>
  </div>
</AdminSection>
