---
import type { NotFoundContent } from "@/lib/content-defaults";
import FormattedText from "@/components/ui/FormattedText.astro";

export interface Props {
  content: NotFoundContent;
}

const { content } = Astro.props;
---

<section class="border-b border-line bg-bg py-14 sm:py-20">
  <div class="mx-auto max-w-[1360px] px-6 text-center sm:px-10">
    <p class="font-display text-6xl font-semibold text-green/30">
      <FormattedText text={content.code} as="span" />
    </p>
    <h1 class="mt-4 text-2xl font-semibold text-heading">
      <FormattedText text={content.title} as="span" />
    </h1>
    <p class="mx-auto mt-3 max-w-md text-muted">
      <FormattedText text={content.lead} as="span" />
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      {content.buttons.map((button, index) => (
        <a
          href={button.href}
          class:list={[
            "inline-flex items-center justify-center rounded-[var(--radius-btn)] px-5 py-2.5 text-sm font-semibold no-underline",
            index === 0
              ? "bg-green text-white hover:bg-green-deep"
              : "border border-line bg-white text-text hover:border-green",
          ]}
        >
          <FormattedText text={button.label} as="span" />
        </a>
      ))}
    </div>
  </div>
</section>
