---
import { formatDateTR, type BlogPost } from "@/lib/blog";

export interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
---

<article class="ui-card law-card-accent flex h-full flex-col border border-line bg-white p-6 sm:p-7">
  <p class="text-xs font-semibold uppercase tracking-[0.12em] text-green-deep">{post.category}</p>
  <h2 class="mt-2 font-display text-lg font-semibold text-heading">
    <a href={`/blog/${post.slug}`} class="text-heading no-underline hover:text-green-deep">
      {post.title}
    </a>
  </h2>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{post.excerpt}</p>
  <footer class="mt-4 flex items-center justify-between gap-3 text-xs text-muted">
    <time datetime={post.publishedAt.toISOString()}>{formatDateTR(post.publishedAt)}</time>
    <a href={`/blog/${post.slug}`} class="font-semibold text-green-deep no-underline hover:text-green">
      Oku
    </a>
  </footer>
</article>
