---
export interface Props {
  id?: string;
}

const patternId = `lf-${Astro.props.id ?? "default"}`;
---

<svg class="pointer-events-none absolute inset-0 opacity-[0.15]" aria-hidden="true" preserveAspectRatio="none">
  <defs>
    <pattern id={patternId} width="150" height="150" patternUnits="userSpaceOnUse" patternTransform="rotate(10)">
      <path d="M34 24 C22 34 20 60 30 86 C60 78 80 55 76 28 C62 39 45 39 34 51" fill="none" stroke="var(--color-leaf)" stroke-width="1.4" />
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill={`url(#${patternId})`} />
</svg>
