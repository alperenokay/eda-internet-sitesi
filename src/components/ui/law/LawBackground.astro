---
import LawScales from "./LawScales.astro";
import LawColumn from "./LawColumn.astro";
import LawGavel from "./LawGavel.astro";
import LawBook from "./LawBook.astro";
import LawLaurel from "./LawLaurel.astro";

export interface Props {
  tone?: "light" | "dark";
  density?: "hero" | "section" | "panel" | "footer" | "band";
  class?: string;
}

const { tone = "light", density = "section", class: className } = Astro.props;

const toneClass = tone === "dark" ? "law-bg--dark" : "law-bg--light";
---

<div
  class:list={["law-bg pointer-events-none absolute inset-0 z-0 overflow-hidden", toneClass, className]}
  aria-hidden="true"
>
  {density === "hero" && (
    <>
      <div class="law-fig law-fig--lg law-fig--hero-scale"><LawScales /></div>
      <div class="law-fig law-fig--md law-fig--hero-column"><LawColumn /></div>
      <div class="law-fig law-fig--sm law-fig--hero-book"><LawBook /></div>
    </>
  )}

  {density === "section" && (
    <>
      <div class="law-fig law-fig--md law-fig--section-scale"><LawScales /></div>
      <div class="law-fig law-fig--sm law-fig--section-book"><LawBook /></div>
      <div class="law-fig law-fig--sm law-fig--section-column"><LawColumn /></div>
    </>
  )}

  {density === "panel" && (
    <>
      <div class="law-fig law-fig--lg law-fig--panel-scale"><LawScales /></div>
      <div class="law-fig law-fig--sm law-fig--panel-laurel"><LawLaurel /></div>
      <div class="law-fig law-fig--md law-fig--panel-column"><LawColumn /></div>
    </>
  )}

  {density === "footer" && (
    <>
      <div class="law-fig law-fig--md law-fig--footer-scale"><LawScales /></div>
      <div class="law-fig law-fig--sm law-fig--footer-book"><LawBook /></div>
      <div class="law-fig law-fig--sm law-fig--footer-column"><LawColumn /></div>
    </>
  )}

  {density === "band" && (
    <>
      <div class="law-fig law-fig--md law-fig--band-scale"><LawScales /></div>
      <div class="law-fig law-fig--sm law-fig--band-gavel"><LawGavel /></div>
    </>
  )}
</div>
