---
export interface Props {
  variant?: "brand" | "watermark";
  class?: string;
}

const { variant = "brand", class: className } = Astro.props;
const stroke = variant === "watermark" ? "currentColor" : "var(--color-green)";
const fill = variant === "watermark" ? "currentColor" : "var(--color-green)";
---

<svg
  viewBox="0 0 48 48"
  fill="none"
  aria-hidden="true"
  class:list={[variant === "brand" ? "h-11 w-11 sm:h-12 sm:w-12" : "h-full w-full", className]}
>
  <circle cx="24" cy="24" r="22" stroke={stroke} stroke-width="1.5" opacity={variant === "watermark" ? "1" : "0.35"} />
  <path d="M21 34h6l-.8 4h-4.4L21 34Z" stroke={stroke} stroke-width="1.2" stroke-linejoin="round" />
  <path d="M24 34V16" stroke={stroke} stroke-width="1.4" stroke-linecap="round" />
  <circle cx="24" cy="13" r="1.4" fill={fill} opacity="0.85" />
  <path d="M12 18h24" stroke={stroke} stroke-width="1.4" stroke-linecap="round" />
  <path
    d="M12 20v6c0 4 3 6.5 6.5 6.5S25 30 25 26v-6"
    stroke={stroke}
    stroke-width="1.3"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <path
    d="M36 20v6c0 4-3 6.5-6.5 6.5S23 30 23 26v-6"
    stroke={stroke}
    stroke-width="1.3"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>
