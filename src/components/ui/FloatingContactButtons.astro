---
export interface Props {
  phone: string;
}

const { phone } = Astro.props;

const digits = phone.replace(/\D/g, "");
const telHref = digits.startsWith("0") ? `tel:+90${digits.slice(1)}` : `tel:+${digits}`;
const whatsappDigits = digits.startsWith("0") ? `90${digits.slice(1)}` : digits;
const whatsappHref = `https://wa.me/${whatsappDigits}`;
---

<aside class="floating-contact" aria-label="Hızlı iletişim">
  <a
    href={telHref}
    class="floating-contact__btn floating-contact__btn--call"
    aria-label="Telefon ile ara"
  >
    <span class="floating-contact__halo" aria-hidden="true"></span>
    <svg class="floating-contact__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M8.5 4.2c.4-.9 1.4-1.3 2.3-.9l1.8.8c.8.4 1.1 1.3.8 2.1l-.7 1.8c-.2.5-.1 1.1.3 1.5a11.8 11.8 0 0 0 5.2 5.2c.4.4 1 .5 1.5.3l1.8-.7c.8-.3 1.7 0 2.1.8l.8 1.8c.4.9 0 1.9-.9 2.3l-1.6.7c-1.2.5-2.6.3-3.7-.4a15.2 15.2 0 0 1-5.5-5.5c-.7-1.1-.9-2.5-.4-3.7l.7-1.6Z"
        fill="currentColor"
      />
    </svg>
  </a>
  <a
    href={whatsappHref}
    class="floating-contact__btn floating-contact__btn--whatsapp"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="WhatsApp ile yazın"
  >
    <span class="floating-contact__halo" aria-hidden="true"></span>
    <svg class="floating-contact__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        fill="currentColor"
        d="M12 2a10 10 0 0 0-8.7 15l-1.1 4 4.1-1.1A10 10 0 1 0 12 2Zm5.2 14.3c-.2.6-1.2 1.1-1.7 1.1-.4 0-1.1.2-3.4-.9-2.8-1.3-4.6-4.5-4.7-4.7-.2-.3-1.6-2.2-.2-3.6.4-.4 1-.6 1.5-.6.2 0 .4 0 .5.1.2 0 .4.1.5.4.2.5.7 1.7.7 1.8 0 .2 0 .4-.1.6-.1.1-.2.3-.3.4-.1.1-.2.2-.1.4.1.2.6 1.1 1.4 1.8 1 1 2.2 1.3 2.5 1.4.2.1.4.1.5 0 .2-.1.8-.6 1-.8.2-.2.4-.2.6-.1l2.4 1.1c.2.1.3.2.3.4 0 .2-.1.5-.3.7Z"
      />
    </svg>
  </a>
</aside>
