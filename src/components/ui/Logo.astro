---
import LawSeal from "@/components/ui/law/LawSeal.astro";

export interface Props {
  variant?: "header" | "footer";
  class?: string;
}

const { variant = "header", class: className } = Astro.props;

const textClass =
  variant === "header"
    ? "text-heading sm:text-[1.5rem]"
    : "text-white sm:text-[1.35rem]";
const subClass = variant === "header" ? "text-muted" : "text-white/65";
---

<div class:list={["flex items-center gap-3.5", className]}>
  <LawSeal variant="brand" />
  <div class:list={["font-display font-semibold leading-[1.05] tracking-tight", textClass]}>
    <span>Sağır Hukuk</span>
    <span class:list={["block text-[0.58em] font-medium tracking-[0.06em] uppercase", subClass]}>
      & Danışmanlık
    </span>
  </div>
</div>
