---
import Container from "./Container.astro";
import FormattedText from "./FormattedText.astro";
import LawBackground from "./law/LawBackground.astro";

export interface Props {
  variant?: "default" | "soft" | "panel";
  id?: string;
  eyebrow?: string;
  title?: string;
  lead?: string;
  caption?: string;
  tight?: boolean;
}

const {
  variant = "default",
  id,
  eyebrow,
  title,
  lead,
  caption,
  tight = false,
} = Astro.props;

const variants = {
  default: "relative overflow-hidden",
  soft: "relative overflow-hidden border-y border-line/80 bg-white/35",
  panel: "relative overflow-hidden bg-panel text-white",
};

const eyebrowClass =
  variant === "panel"
    ? "text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-leaf"
    : "text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-green-deep";
---

<section
  class:list={[variants[variant], tight ? "py-14 sm:py-16" : "py-[4.125rem] sm:py-[4.125rem]"]}
  id={id}
>
  {variant === "default" && <LawBackground tone="light" density="section" />}
  {variant === "soft" && <LawBackground tone="light" density="section" />}
  {variant === "panel" && <LawBackground tone="dark" density="panel" />}
  <slot name="backdrop" />
  <Container>
    {(eyebrow || title || lead || caption) && (
      <div class="relative z-[1] max-w-2xl">
        {eyebrow && (
          <FormattedText text={eyebrow} as="p" class={eyebrowClass} />
        )}
        {title && (
          <h2
            class:list={[
              "mt-2 font-display text-3xl font-semibold tracking-tight sm:text-[2.1rem]",
              variant === "panel" ? "text-white" : "text-heading",
            ]}
          >
            <FormattedText text={title} as="span" />
          </h2>
        )}
        {caption && (
          <p
            class:list={[
              "mt-1 text-[0.98rem]",
              variant === "panel" ? "text-white/75" : "text-muted",
            ]}
          >
            <FormattedText text={caption} as="span" />
          </p>
        )}
        {lead && (
          <p
            class:list={[
              "mt-3 text-base leading-relaxed",
              variant === "panel" ? "text-white/75" : "text-muted",
            ]}
          >
            <FormattedText text={lead} as="span" />
          </p>
        )}
      </div>
    )}
    <slot name="head" />
    <div class:list={["relative z-[1]", (eyebrow || title || lead || caption) && "mt-6"]}>
      <slot />
    </div>
  </Container>
</section>
