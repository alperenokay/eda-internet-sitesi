---
import Container from "@/components/ui/Container.astro";
import Eyebrow from "@/components/ui/Eyebrow.astro";
import LeafPattern from "@/components/ui/botanic/LeafPattern.astro";
import RecycleLoop from "@/components/ui/botanic/RecycleLoop.astro";

export interface Props {
  showPositioning?: boolean;
}

const { showPositioning = false } = Astro.props;
---

<section class="relative overflow-hidden bg-panel text-white">
  <LeafPattern id="differentiator" />
  <Container>
    <div class="relative z-[1] grid items-center gap-10 py-[4.5rem] lg:grid-cols-[1.1fr_0.9fr] lg:gap-11">
      <div>
        <Eyebrow tone="on-dark">Farkımız</Eyebrow>
        <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-white sm:text-[2.1rem]">
          Aynı veri, iki regülasyon
        </h2>
        <p class="mt-4 max-w-[44ch] text-base leading-relaxed text-white/75">
          PPWR için topladığınız ambalaj verisi, CSRD raporlamanızı da besleyebilir. Marine
          Emission bu iki tarafı tek veri modeliyle çalıştırır, böylece aynı işi iki kez yapmazsınız.
        </p>
        <p class="mt-5 text-xs leading-relaxed text-white/45">
          Bu içerik danışmanlık niteliğindedir, bağlayıcı hukuki görüş değildir.
          {showPositioning && (
            <>
              {" "}
              Marine Emission danışman ve kolaylaştırıcıdır, doğrulama kuruluşu değildir.
              Doğrulama kuruluşu seçiminde yönlendirir, süreci kolaylaştırır.
            </>
          )}
        </p>
      </div>
      <div class="flex justify-center">
        <RecycleLoop />
      </div>
    </div>
  </Container>
</section>
