---
import LawSeal from "@/components/ui/law/LawSeal.astro";
import { site } from "@/lib/site";
---

<aside class="trust-panel" aria-label="Büro özeti">
  <div class="trust-panel__seal">
    <LawSeal variant="watermark" class="text-white" />
  </div>
  <div class="relative z-[1] min-w-0 flex-1">
    <p class="text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-leaf">Büro</p>
    <p class="mt-1 font-display text-[1.65rem] leading-tight text-white sm:text-[1.85rem]">
      {site.attorney}
    </p>
    <p class="mt-1 text-sm text-white/65">{site.brandFull}</p>
    <ul class="mt-5 space-y-2.5 text-sm text-white/78" role="list">
      <li>
        <span class="text-white/50">Telefon: </span>
        <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="text-white no-underline hover:text-leaf">
          {site.phone}
        </a>
      </li>
      <li>
        <span class="text-white/50">E-posta: </span>
        <a href={`mailto:${site.email}`} class="text-white no-underline hover:text-leaf">
          {site.email}
        </a>
      </li>
      <li>
        <span class="text-white/50">Saatler: </span>
        {site.workingHours}
      </li>
    </ul>
  </div>
  <div class="relative z-[1] hidden shrink-0 sm:block">
    <LawSeal variant="brand" />
  </div>
</aside>
