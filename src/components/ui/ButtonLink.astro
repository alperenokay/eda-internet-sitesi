---
export interface Props {
  href: string;
  variant?: "primary" | "ghost" | "ghost-dark";
}

const { href, variant = "primary" } = Astro.props;

const base =
  "inline-flex items-center justify-center rounded-[var(--radius-btn)] px-5 py-3 text-[0.92rem] font-semibold no-underline transition-colors";

const variants = {
  primary: `${base} bg-panel text-white hover:bg-panel-2`,
  ghost: `${base} border border-line bg-white text-heading hover:border-green hover:text-green-deep`,
  "ghost-dark": `${base} border border-white/30 bg-transparent text-white hover:border-leaf hover:text-leaf`,
};
---

<a href={href} class={variants[variant]}>
  <slot />
</a>
