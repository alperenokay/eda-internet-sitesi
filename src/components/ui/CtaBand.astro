---
import Container from "./Container.astro";
import ButtonLink from "./ButtonLink.astro";

export interface Props {
  title: string;
  text: string;
  buttonHref: string;
  buttonLabel: string;
}

const { title, text, buttonHref, buttonLabel } = Astro.props;
---

<section class="border-t border-line bg-bg-2 py-14 sm:py-16">
  <Container>
    <div class="flex flex-wrap items-center justify-between gap-6">
      <div class="max-w-xl">
        <h2 class="font-display text-2xl font-semibold text-heading sm:text-3xl">{title}</h2>
        <p class="mt-2 text-muted">{text}</p>
      </div>
      <ButtonLink href={buttonHref} variant="primary">{buttonLabel}</ButtonLink>
    </div>
  </Container>
</section>
