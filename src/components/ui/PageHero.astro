---
import Container from "./Container.astro";
import ButtonLink from "./ButtonLink.astro";
import CountdownPanel from "./CountdownPanel.astro";
import Eyebrow from "./Eyebrow.astro";
import Chip from "./Chip.astro";
import HeroGlow from "./botanic/HeroGlow.astro";
import HeroBotanic from "./botanic/HeroBotanic.astro";

export interface Props {
  chip?: string;
  title: string;
  titleHighlight?: string;
  lead: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  showCountdown?: boolean;
  hideActions?: boolean;
}

const {
  chip,
  title,
  titleHighlight,
  lead,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
  showCountdown = true,
  hideActions = false,
} = Astro.props;

function renderTitle() {
  if (titleHighlight && title.includes(titleHighlight)) {
    const [before, after] = title.split(titleHighlight);
    return { before, after };
  }
  return null;
}

const titleParts = titleHighlight ? renderTitle() : null;
---

<section class="relative overflow-hidden">
  <HeroGlow />
  <HeroBotanic />
  <Container>
    <div class="relative grid items-center gap-10 py-16 sm:gap-14 sm:py-[5.5rem] lg:grid-cols-[1.35fr_0.95fr]">
      <div class="relative z-[1]">
        {chip && (
          <div class="mb-5 flex flex-wrap items-center gap-3.5">
            {chip.includes(" · ") ? (
              <>
                <Eyebrow>{chip.split(" · ")[0]}</Eyebrow>
                <Chip>{chip.split(" · ").slice(1).join(" · ")}</Chip>
              </>
            ) : (
              <Chip>{chip}</Chip>
            )}
          </div>
        )}
        <h1 class="font-display text-4xl font-semibold tracking-tight sm:text-5xl lg:text-[3.7rem] lg:leading-[1.06]">
          {titleParts ? (
            <>
              {titleParts.before}
              <span class="text-green">{titleHighlight}</span>
              {titleParts.after}
            </>
          ) : (
            title
          )}
        </h1>
        <p class="mt-5 max-w-[50ch] text-[1.16rem] leading-relaxed text-muted">
          <slot name="lead">{lead}</slot>
        </p>
        {!hideActions && (
          <div class="mt-8 flex flex-wrap gap-3">
            <ButtonLink href={primaryHref} variant="primary">{primaryLabel}</ButtonLink>
            {secondaryHref && secondaryLabel && (
              <ButtonLink href={secondaryHref} variant="ghost">{secondaryLabel}</ButtonLink>
            )}
          </div>
        )}
      </div>
      {showCountdown && (
        <div class="relative z-[1]">
          <slot name="aside">
            <CountdownPanel />
          </slot>
        </div>
      )}
    </div>
  </Container>
</section>
