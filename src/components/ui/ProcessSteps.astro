---
export interface Step {
  title: string;
  text: string;
}

export interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<ol class="process-steps mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6" role="list">
  {steps.map((step, index) => (
    <li class="relative">
      <div
        class="relative z-[1] flex h-11 w-11 items-center justify-center rounded-full border-2 border-green bg-white font-display text-base font-semibold text-green-deep"
        aria-hidden="true"
      >
        {index + 1}
      </div>
      <h3 class="mt-4 font-display text-base font-semibold text-heading">{step.title}</h3>
      <p class="mt-2 text-sm leading-relaxed text-muted">{step.text}</p>
    </li>
  ))}
</ol>
