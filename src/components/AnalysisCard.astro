---
import Card from "@/components/ui/Card.astro";
import Chip from "@/components/ui/Chip.astro";

export interface Props {
  title: string;
  summary: string;
  threshold: string | null;
  slug: string;
  featured?: boolean;
}

const { title, summary, threshold, slug, featured = false } = Astro.props;
---

<Card id={slug} title={title} featured={featured}>
  {summary}
  {threshold && (
    <p slot="footer">
      <Chip>{threshold}</Chip>
    </p>
  )}
  <a
    slot="footer"
    href={`/analizler?analiz=${slug}#basvuru`}
    class="mt-3 inline-flex text-sm font-semibold text-green-deep no-underline hover:text-green"
  >
    Bu analiz için başvur
  </a>
</Card>
