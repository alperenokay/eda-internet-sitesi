---
import { getSite } from "@/lib/content";
import FormattedText from "@/components/ui/FormattedText.astro";

export interface Props {
  directionsLabel?: string;
}

const { directionsLabel = "Google Maps'te yol tarifi al" } = Astro.props;
const site = await getSite();
---

<div class="overflow-hidden rounded-[var(--radius-card)] border border-line bg-white">
  <iframe
    title="Sağır Hukuk ofis konumu, Konak İzmir"
    src={site.mapEmbedUrl}
    class="block h-[280px] w-full border-0 sm:h-[360px] lg:h-[420px]"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    allowfullscreen
  ></iframe>
</div>
<p class="mt-3 text-sm text-muted">
  <a
    href={site.mapsDirectionsUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="font-medium text-green-deep no-underline hover:text-green"
  >
    <FormattedText text={directionsLabel} as="span" />
  </a>
  · {site.address}
</p>
