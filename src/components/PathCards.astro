---
import Section from "@/components/ui/Section.astro";
import Card from "@/components/ui/Card.astro";
import Chip from "@/components/ui/Chip.astro";

const paths = [
  {
    title: "Danışmanlık",
    text: "PPWR, CSRD, Green Claims ve genel uyum için danışmanlık. Ücretsiz ön değerlendirmeyle başlayın.",
    href: "/danismanlik#basvuru",
    cta: "Danışmanlık başvurusu",
  },
  {
    title: "Analiz",
    text: "PFAS, ağır metal, geri dönüştürülebilirlik ve diğer ambalaj analizleri için başvuru.",
    href: "/analizler",
    cta: "Analiz talep et",
  },
];
---

<Section variant="soft" eyebrow="Başlangıç" title="Nereden başlarsınız">
  <div class="grid gap-5 sm:grid-cols-2">
    {paths.map((path) => (
      <Card title={path.title}>
        {path.text}
        <a
          slot="footer"
          href={path.href}
          class="inline-flex text-sm font-semibold text-green-deep no-underline hover:text-green"
        >
          {path.cta}
        </a>
      </Card>
    ))}
  </div>
</Section>
