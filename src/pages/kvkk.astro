---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { applyKvkkPlaceholders, getContent, getSite } from "@/lib/content";
import { getKvkkContactEmail, getRetentionMonths } from "@/lib/kvkk";
import { renderMarkdown } from "@/lib/render-markdown";
import FormattedText from "@/components/ui/FormattedText.astro";

const kvkk = await getContent("kvkk");
const site = await getSite();
const retentionMonths = getRetentionMonths();
const contactEmail = getKvkkContactEmail();

const bodyMd = applyKvkkPlaceholders(kvkk.bodyMd, {
  brandFull: site.brandFull,
  attorney: site.attorney,
  domain: site.domain,
  contactEmail,
  retentionMonths: String(retentionMonths),
});

const bodyHtml = renderMarkdown(bodyMd);
---

<BaseLayout
  title={kvkk.seo.title}
  description={kvkk.seo.description}
  path="/kvkk"
  keywords={kvkk.seo.keywords}
>
  <article class="border-b border-line bg-white">
    <div class="mx-auto max-w-[760px] px-6 py-14 sm:px-10">
      <h1 class="text-3xl font-semibold tracking-tight text-heading">
        {kvkk.pageTitle}
      </h1>
      <p class="mt-3 text-sm text-muted">Son güncelleme: {kvkk.lastUpdated}</p>

      <div class="prose mt-10 max-w-none text-text" set:html={bodyHtml} />

      <p class="mt-8 rounded-[var(--radius-sm)] border border-line bg-surface px-4 py-3 text-sm text-muted">
        <FormattedText text={kvkk.disclaimer} as="span" />
      </p>
    </div>
  </article>
</BaseLayout>
