---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminContentForm from "@/components/admin/AdminContentForm.astro";
import AdminContentSidebar from "@/components/admin/AdminContentSidebar.astro";
import { getContent, parseContentKey } from "@/lib/content";
import { CONTENT_REGISTRY } from "@/lib/content-defaults";

const key = parseContentKey(Astro.params.key);
if (!key) {
  return Astro.redirect("/admin/icerik");
}

const data = await getContent(key);
const meta = CONTENT_REGISTRY[key];
---

<AdminLayout title={meta.label}>
  <div class="mb-6">
    <p class="text-sm text-muted">
      <a href="/admin" class="text-green-deep no-underline hover:text-green">Özet</a>
      <span aria-hidden="true"> / </span>
      <a href="/admin/icerik" class="text-green-deep no-underline hover:text-green">Sayfa metinleri</a>
      <span aria-hidden="true"> / </span>
      {meta.label}
    </p>
    <h1 class="mt-2 font-display text-2xl font-semibold">{meta.label}</h1>
    <p class="mt-2 max-w-2xl text-sm text-muted">{meta.description}</p>
    <div class="mt-3 flex flex-wrap gap-3 text-sm">
      {meta.publicPath && (
        <a href={meta.publicPath} target="_blank" rel="noopener" class="font-semibold text-green-deep no-underline hover:text-green">
          Canlı sitede aç ({meta.publicPath})
        </a>
      )}
      <span class="text-muted">Sol menüden bölüme atlayabilirsiniz.</span>
    </div>
  </div>

  <div class="grid gap-8 lg:grid-cols-[240px_minmax(0,1fr)]">
    <AdminContentSidebar contentKey={key} />
    <AdminContentForm contentKey={key} data={data} />
  </div>
</AdminLayout>
