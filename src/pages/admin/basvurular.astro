---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminApplicationCard from "@/components/admin/AdminApplicationCard.astro";
import { fetchContactMessages } from "@/lib/admin";

let messages: Awaited<ReturnType<typeof fetchContactMessages>> = [];

try {
  messages = await fetchContactMessages();
} catch (err) {
  console.warn("[admin/basvurular] veriler alınamadı:", err);
}
---

<AdminLayout title="İletişim mesajları">
  <h1 class="font-display text-2xl font-semibold">İletişim mesajları</h1>
  <p class="mt-2 max-w-2xl text-sm text-muted">
    İletişim formundan gelen talepler. Durum güncellemesi ve KVKK kapsamında anonimleştirme buradan yapılır.
  </p>

  <section class="mt-8">
    {messages.length > 0 ? (
      <ul class="space-y-4" role="list">
        {messages.map((row) => (
          <AdminApplicationCard
            id={row.id}
            fullName={row.full_name}
            email={row.email}
            status={row.status}
            createdAt={row.created_at}
          >
            <dl class="grid gap-1 text-xs text-muted">
              {row.subject && (
                <div>
                  <dt class="inline font-medium text-ink">Konu: </dt>
                  <dd class="inline">{row.subject}</dd>
                </div>
              )}
              <div>
                <dt class="inline font-medium text-ink">Mesaj: </dt>
                <dd class="inline whitespace-pre-wrap">{row.message}</dd>
              </div>
            </dl>
          </AdminApplicationCard>
        ))}
      </ul>
    ) : (
      <p class="mt-3 text-sm text-muted">Henüz iletişim mesajı yok.</p>
    )}
  </section>
</AdminLayout>

<script>
  async function postJson(url: string, body: Record<string, unknown>) {
    const res = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    return res.json();
  }

  document.querySelectorAll(".status-select").forEach((select) => {
    select.addEventListener("change", async (e) => {
      const el = e.target as HTMLSelectElement;
      const li = el.closest("li");
      const id = Number(li?.dataset.id);
      const previous = el.dataset.current;
      const status = el.value;
      const data = await postJson("/api/admin/status", { id, status, previous_status: previous });
      if (data.ok) {
        el.dataset.current = status;
        window.location.reload();
      } else {
        alert(data.error || "Güncellenemedi.");
        if (previous) el.value = previous;
      }
    });
  });

  document.querySelectorAll(".delete-app-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = Number((btn as HTMLElement).dataset.id);
      if (!confirm("Bu kayıt anonimleştirilecek. Emin misiniz?")) return;
      const data = await postJson("/api/admin/application", { id });
      if (data.ok) window.location.reload();
      else alert(data.error || "Silinemedi.");
    });
  });
</script>
