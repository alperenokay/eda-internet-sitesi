---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { fetchAllBlogPostsAdmin, formatAdminDate, statusLabel } from "@/lib/admin";

let posts: Awaited<ReturnType<typeof fetchAllBlogPostsAdmin>> = [];

try {
  posts = await fetchAllBlogPostsAdmin();
} catch (err) {
  console.warn("[admin/blog] liste alınamadı:", err);
}
---

<AdminLayout title="Blog yazıları">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <h1 class="font-display text-2xl font-semibold">Blog yazıları</h1>
    <a
      href="/admin/blog/new"
      class="inline-flex items-center rounded-[var(--radius-btn)] bg-green px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-green-deep"
    >
      Yeni yazı
    </a>
  </div>

  {posts.length > 0 ? (
    <div class="mt-6 overflow-x-auto">
      <table class="w-full min-w-[720px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-line text-left text-muted">
            <th class="py-2 pr-4 font-medium">Başlık</th>
            <th class="py-2 pr-4 font-medium">Durum</th>
            <th class="py-2 pr-4 font-medium">Yayın</th>
            <th class="py-2 font-medium">İşlemler</th>
          </tr>
        </thead>
        <tbody>
          {posts.map((post) => (
            <tr class="border-b border-line" data-post-id={post.id}>
              <td class="py-3 pr-4">
                <span class="font-medium text-ink">{post.title}</span>
                <span class="mt-0.5 block text-xs text-muted">/blog/{post.slug}</span>
              </td>
              <td class="py-3 pr-4">{statusLabel(post.status)}</td>
              <td class="py-3 pr-4 text-muted">
                {post.published_at ? formatAdminDate(post.published_at) : "-"}
              </td>
              <td class="py-3">
                <div class="flex flex-wrap items-center gap-3">
                  <a
                    href={`/admin/blog/${post.id}`}
                    class="font-semibold text-green-deep no-underline hover:text-green"
                  >
                    Düzenle
                  </a>
                  {post.status === "published" && (
                    <a
                      href={`/blog/${post.slug}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-muted no-underline hover:text-ink"
                    >
                      Sitede gör
                    </a>
                  )}
                  <button
                    type="button"
                    class="delete-post-btn text-signal hover:underline"
                    data-id={post.id}
                    data-title={post.title}
                  >
                    Sil
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <p class="mt-6 text-muted">
      Henüz yazı yok.
      <a href="/admin/blog/new" class="font-semibold text-green-deep no-underline hover:text-green">İlk yazıyı ekleyin.</a>
    </p>
  )}

  <script>
    document.querySelectorAll(".delete-post-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = Number((btn as HTMLButtonElement).dataset.id);
        const title = (btn as HTMLButtonElement).dataset.title || "Bu yazı";
        if (!id) return;
        if (!confirm(`"${title}" silinsin mi? Bu işlem geri alınamaz.`)) return;

        btn.setAttribute("disabled", "true");
        try {
          const res = await fetch("/api/admin/blog", {
            method: "DELETE",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id }),
          });
          const data = await res.json();
          if (data.ok) {
            btn.closest("tr")?.remove();
          } else {
            alert(data.error || "Silme sırasında bir sorun oluştu.");
            btn.removeAttribute("disabled");
          }
        } catch {
          alert("Bağlantı sorunu oluştu.");
          btn.removeAttribute("disabled");
        }
      });
    });
  </script>
</AdminLayout>
