---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { fetchAllBlogPostsAdmin, formatAdminDate, statusLabel } from "@/lib/admin";
import { STATIC_BLOG_POSTS } from "@/lib/blog-data";

let posts: Awaited<ReturnType<typeof fetchAllBlogPostsAdmin>> = [];

try {
  posts = await fetchAllBlogPostsAdmin();
} catch (err) {
  console.warn("[admin/blog] liste alınamadı:", err);
}
---

<AdminLayout title="Yayınlar">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="font-display text-2xl font-semibold">Yayınlar</h1>
      <p class="mt-2 max-w-xl text-sm text-muted">
        Sitede görünen blog yazıları. Liste sayfası metinleri (başlık, açıklama) için
        <a href="/admin/icerik/blog_page" class="font-semibold text-green-deep no-underline hover:text-green">Yayınlar sayfa metinleri</a>
        bölümünü kullanın.
      </p>
    </div>
    <a
      href="/admin/blog/new"
      class="inline-flex items-center rounded-[var(--radius-btn)] bg-green px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-green-deep"
    >
      Yeni yazı
    </a>
  </div>

  {posts.length > 0 ? (
    <div class="mt-6 overflow-x-auto">
      <table class="w-full min-w-[720px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-line text-left text-muted">
            <th class="py-2 pr-4 font-medium">Başlık</th>
            <th class="py-2 pr-4 font-medium">Durum</th>
            <th class="py-2 pr-4 font-medium">Yayın</th>
            <th class="py-2 font-medium">İşlemler</th>
          </tr>
        </thead>
        <tbody>
          {posts.map((post) => (
            <tr class="border-b border-line" data-post-id={post.id}>
              <td class="py-3 pr-4">
                <span class="font-medium text-ink">{post.title}</span>
                <span class="mt-0.5 block text-xs text-muted">/blog/{post.slug}</span>
              </td>
              <td class="py-3 pr-4">{statusLabel(post.status)}</td>
              <td class="py-3 pr-4 text-muted">
                {post.published_at ? formatAdminDate(post.published_at) : "-"}
              </td>
              <td class="py-3">
                <div class="flex flex-wrap items-center gap-3">
                  <a
                    href={`/admin/blog/${post.id}`}
                    class="font-semibold text-green-deep no-underline hover:text-green"
                  >
                    Düzenle
                  </a>
                  {post.status === "published" && (
                    <a
                      href={`/blog/${post.slug}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-muted no-underline hover:text-ink"
                    >
                      Sitede gör
                    </a>
                  )}
                  <button
                    type="button"
                    class="delete-post-btn text-signal hover:underline"
                    data-id={post.id}
                    data-title={post.title}
                  >
                    Sil
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <div class="mt-6 space-y-4">
      <p class="text-muted">
        Henüz yazı yok.
        <a href="/admin/blog/new" class="font-semibold text-green-deep no-underline hover:text-green">İlk yazıyı ekleyin</a>
        veya mevcut {STATIC_BLOG_POSTS.length} statik yazıyı içe aktarın.
      </p>
      <button
        type="button"
        id="seed-blog-btn"
        class="rounded-[var(--radius-btn)] border border-line bg-paper px-4 py-2 text-sm font-semibold text-green-deep hover:border-green"
      >
        Statik yazıları içe aktar ({STATIC_BLOG_POSTS.length})
      </button>
      <p id="seed-blog-msg" class="hidden text-sm" role="status"></p>
    </div>
  )}

  <script>
    document.getElementById("seed-blog-btn")?.addEventListener("click", async () => {
      const btn = document.getElementById("seed-blog-btn") as HTMLButtonElement;
      const msg = document.getElementById("seed-blog-msg") as HTMLParagraphElement;
      if (!btn || !msg) return;
      btn.disabled = true;
      msg.classList.remove("hidden");
      msg.textContent = "İçe aktarılıyor...";
      try {
        const res = await fetch("/api/admin/blog/seed", { method: "POST" });
        const data = await res.json();
        if (data.ok) {
          msg.textContent = `${data.inserted} yazı eklendi, ${data.skipped} zaten vardı. Sayfa yenileniyor...`;
          msg.className = "text-sm text-green-deep";
          window.setTimeout(() => window.location.reload(), 800);
        } else {
          msg.textContent = data.error || "İçe aktarma başarısız.";
          msg.className = "text-sm text-signal";
          btn.disabled = false;
        }
      } catch {
        msg.textContent = "Bağlantı sorunu oluştu.";
        msg.className = "text-sm text-signal";
        btn.disabled = false;
      }
    });

    document.querySelectorAll(".delete-post-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = Number((btn as HTMLButtonElement).dataset.id);
        const title = (btn as HTMLButtonElement).dataset.title || "Bu yazı";
        if (!id) return;
        if (!confirm(`"${title}" silinsin mi? Bu işlem geri alınamaz.`)) return;

        btn.setAttribute("disabled", "true");
        try {
          const res = await fetch("/api/admin/blog", {
            method: "DELETE",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id }),
          });
          const data = await res.json();
          if (data.ok) {
            btn.closest("tr")?.remove();
          } else {
            alert(data.error || "Silme sırasında bir sorun oluştu.");
            btn.removeAttribute("disabled");
          }
        } catch {
          alert("Bağlantı sorunu oluştu.");
          btn.removeAttribute("disabled");
        }
      });
    });
  </script>
</AdminLayout>
