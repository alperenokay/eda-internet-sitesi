---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AnalysisCard from "@/components/AnalysisCard.astro";
import AnalysisForm from "@/components/AnalysisForm";
import PageHero from "@/components/ui/PageHero.astro";
import Section from "@/components/ui/Section.astro";
import {
  FALLBACK_ANALYSES,
  buildAnalysisItemListSchema,
  fetchCatalogAnalyses,
  toFormOptions,
  type AnalysisPreview,
} from "@/lib/analyses";

const title = "PPWR Ambalaj Analizleri";
const description =
  "PFAS, ağır metal, geri dönüştürülebilirlik ve diğer PPWR ambalaj analizleri için başvuru. Marine Emission ile ambalajınızı değerlendirin.";
const keywords =
  "PPWR analizi, PFAS analizi, ağır metal analizi, ambalaj analizi, geri dönüştürülebilirlik analizi, minimizasyon";

let analyses: AnalysisPreview[] = FALLBACK_ANALYSES;

try {
  const rows = await fetchCatalogAnalyses();
  if (rows.length > 0) {
    analyses = rows;
  }
} catch (err) {
  console.warn("[analizler] DB erişilemedi, statik yedek kullanılıyor:", err);
}

const formAnalyses = toFormOptions(analyses);
const initialSlug = Astro.url.searchParams.get("analiz") ?? "";
const jsonLd = [buildAnalysisItemListSchema(analyses)];
---

<BaseLayout
  title={title}
  description={description}
  path="/analizler"
  keywords={keywords}
  jsonLd={jsonLd}
>
  <PageHero
    title="Ambalaj analizleri"
    lead=""
    primaryHref="/danismanlik#basvuru"
    primaryLabel="Ücretsiz ön değerlendirme"
    showCountdown={false}
  >
    <span slot="lead">
      Aşağıdaki analizler için başvuru alıyoruz. Her analiz, PPWR ölçütlerine göre
      ambalajınızın ilgili gereksinimi karşılayıp karşılamadığını değerlendirir.
      Hangi analize ihtiyacınız olduğundan emin değilseniz,
      <a href="/danismanlik#basvuru" class="font-medium text-green-deep no-underline hover:text-green">
        ücretsiz ön değerlendirmeyle
      </a>
      başlayın.
    </span>
  </PageHero>

  <Section variant="soft">
    <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
      {analyses.map((item) => (
        <AnalysisCard
          slug={item.slug}
          title={item.title}
          summary={item.summary}
          threshold={item.threshold}
          featured={item.slug === "ppwr-gap"}
        />
      ))}
    </div>
  </Section>

  <Section variant="default" id="basvuru">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,28rem)] lg:items-start">
      <div>
        <h2 class="font-display text-2xl font-semibold text-heading sm:text-3xl">Analiz başvurusu</h2>
        <p class="mt-3 max-w-lg text-muted">
          Formu doldurun, seçtiğiniz analiz için sizinle iletişime geçelim.
        </p>
        <p class="mt-6 max-w-lg text-xs text-muted">
          Analiz sonuçları ve öneriler danışmanlık niteliğindedir, bağlayıcı hukuki görüş değildir.
        </p>
      </div>
      <div class="rounded-[var(--radius-card)] border border-line bg-bg-2 p-6 sm:p-8">
        <AnalysisForm
          client:load
          analyses={formAnalyses}
          initialSlug={initialSlug}
        />
      </div>
    </div>
  </Section>
</BaseLayout>
