---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/blog/PostCard.astro";
import PageHero from "@/components/ui/PageHero.astro";
import Section from "@/components/ui/Section.astro";
import { fetchPublishedPosts } from "@/lib/blog";
import { getContent } from "@/lib/content";
import FormattedText from "@/components/ui/FormattedText.astro";

const blogPage = await getContent("blog_page");
const posts = await fetchPublishedPosts();
---

<BaseLayout
  title={blogPage.seo.title}
  description={blogPage.seo.description}
  path="/blog"
  keywords={blogPage.seo.keywords}
>
  <PageHero
    eyebrow={blogPage.hero.eyebrow}
    title={blogPage.hero.title}
    titleHighlight={blogPage.hero.titleHighlight}
    lead={blogPage.hero.lead}
    primaryHref={blogPage.hero.primaryHref}
    primaryLabel={blogPage.hero.primaryLabel}
    secondaryHref={blogPage.hero.secondaryHref}
    secondaryLabel={blogPage.hero.secondaryLabel}
  />

  <Section variant="soft" title={blogPage.listSection.title} lead={blogPage.listSection.lead}>
    {posts.length === 0 ? (
      <p class="text-muted">
        <FormattedText text={blogPage.listSection.emptyMessage} as="span" />
      </p>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    )}
  </Section>
</BaseLayout>
