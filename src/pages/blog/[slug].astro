---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/ui/Section.astro";
import ButtonLink from "@/components/ui/ButtonLink.astro";
import { BLOG_DISCLAIMER } from "@/lib/blog-data";
import {
  buildBlogPostingSchema,
  fetchPostBySlug,
  formatDateTR,
} from "@/lib/blog";
import { renderMarkdown } from "@/lib/render-markdown";
import { SITE_URL } from "@/lib/site";
import "@/styles/prose.css";

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect("/404");
}

const post = await fetchPostBySlug(slug);
if (!post) {
  return Astro.redirect("/404");
}

const canonicalPath = `/blog/${post.slug}`;
const canonicalUrl = SITE_URL + canonicalPath;
const pageTitle = post.metaTitle ?? post.title;
const pageDescription = post.metaDesc ?? post.excerpt;
const bodyHtml = renderMarkdown(post.bodyMd);
const jsonLd = buildBlogPostingSchema(post, canonicalUrl);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  path={canonicalPath}
  keywords={post.keywords}
  jsonLd={[jsonLd]}
>
  <Section variant="default" tight>
    <article class="mx-auto max-w-[760px]">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-green-deep">{post.category}</p>
      <h1 class="mt-3 font-display text-3xl font-semibold tracking-tight text-heading sm:text-4xl">
        {post.title}
      </h1>
      <p class="mt-3 text-sm text-muted">
        <time datetime={post.publishedAt.toISOString()}>{formatDateTR(post.publishedAt)}</time>
      </p>
      {post.excerpt && (
        <p class="mt-5 text-base leading-relaxed text-muted">{post.excerpt}</p>
      )}
    </article>
  </Section>

  <Section variant="soft" tight>
    <div class="mx-auto max-w-[760px]">
      <div class="prose" set:html={bodyHtml} />
      <p class="mt-10 rounded-[var(--radius-card)] border border-line bg-white px-4 py-3 text-sm text-muted">
        {BLOG_DISCLAIMER}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <ButtonLink href="/blog" variant="ghost">Tüm yazılar</ButtonLink>
        <ButtonLink href="/iletisim#mesaj" variant="primary">Randevu talebi</ButtonLink>
      </div>
    </div>
  </Section>
</BaseLayout>
