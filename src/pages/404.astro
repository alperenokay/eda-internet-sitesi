---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NotFoundContent from "@/components/NotFoundContent.astro";
import { getContent } from "@/lib/content";

const notFound = await getContent("not_found");

Astro.response.status = 404;
---

<BaseLayout
  title={notFound.seo.title}
  description={notFound.seo.description}
  path="/404"
  noindex
>
  <NotFoundContent content={notFound} />
</BaseLayout>
